---
import { stats } from '../data/portfolio';
---

<section class="border-y border-border bg-surface/40">
  <div class="mx-auto grid max-w-5xl grid-cols-2 gap-px overflow-hidden md:grid-cols-4">
    {
      stats.map((stat, i) => (
        <div
          class="reveal bg-bg px-6 py-10 text-center"
          style={`transition-delay:${i * 80}ms`}
        >
          <p class="font-mono text-4xl font-bold tracking-tight text-gradient sm:text-5xl">
            {stat.value}
          </p>
          <p class="mt-2 text-sm text-muted">{stat.label}</p>
        </div>
      ))
    }
  </div>
</section>
