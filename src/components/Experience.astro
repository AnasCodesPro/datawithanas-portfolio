---
import SectionHeading from './SectionHeading.astro';
import { experience } from '../data/portfolio';

// Wrap impact metrics (e.g. "30%", "3×", "99.9%+", "24 hours") so they pop.
function highlightMetrics(text: string): string {
  return text.replace(
    /(\d[\d.,]*\s?(?:%|×|x\b|hours|minutes|months)?\+?)/g,
    '<span class="font-mono font-semibold text-accent">$1</span>'
  );
}
---

<section id="experience" class="mx-auto max-w-5xl px-6 py-24">
  <SectionHeading
    index="03 / experience"
    title="Where I've delivered"
    subtitle="End-to-end ownership — ingestion, modeling, deployment, and the dashboards leadership actually uses."
  />

  <ol class="relative space-y-12 border-l border-border pl-8 sm:pl-10">
    {
      experience.map((job, i) => (
        <li class="reveal relative" style={`transition-delay:${i * 60}ms`}>
          <span
            class={`absolute -left-[37px] top-1.5 flex h-4 w-4 items-center justify-center rounded-full border-2 sm:-left-[45px] ${
              job.current
                ? 'border-accent bg-accent'
                : 'border-border-strong bg-bg'
            }`}
            aria-hidden="true"
          >
            {job.current && (
              <span class="h-1.5 w-1.5 rounded-full bg-bg" />
            )}
          </span>

          <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
            <h3 class="font-display text-lg font-semibold text-text">
              {job.role}
              <span class="text-accent"> · {job.company}</span>
            </h3>
            <span class="font-mono text-xs text-faint">{job.period}</span>
          </div>

          <ul class="mt-4 space-y-2.5">
            {job.highlights.map((point) => (
              <li class="flex gap-3 text-sm leading-relaxed text-muted">
                <svg
                  class="mt-1.5 h-3 w-3 flex-none text-accent/70"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <polyline points="9 18 15 12 9 6" />
                </svg>
                <span set:html={highlightMetrics(point)} />
              </li>
            ))}
          </ul>
        </li>
      ))
    }
  </ol>
</section>
