---
import { profile } from '../data/portfolio';

const channels = [
  {
    label: 'Email',
    value: profile.email,
    href: `mailto:${profile.email}`,
    icon: 'mail',
  },
  {
    label: 'LinkedIn',
    value: 'in/muhammadanaskhi',
    href: profile.linkedin,
    icon: 'linkedin',
  },
  {
    label: 'GitHub',
    value: 'AnasCodesPro',
    href: profile.github,
    icon: 'github',
  },
];
---

<section id="contact" class="relative overflow-hidden border-t border-border">
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-dotgrid opacity-30"></div>
    <div
      class="absolute left-1/2 top-1/2 h-[360px] w-[560px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-30 blur-[120px]"
      style="background: radial-gradient(circle, rgba(56,189,248,0.30), transparent 70%);"
    >
    </div>
  </div>

  <div class="mx-auto max-w-5xl px-6 py-28 text-center">
    <p class="reveal mb-3 font-mono text-sm tracking-widest text-accent">06 / contact</p>
    <h2 class="reveal mx-auto max-w-2xl font-display text-3xl font-semibold tracking-tight text-text sm:text-5xl">
      Let's build something <span class="text-gradient">data-driven</span>.
    </h2>
    <p class="reveal mx-auto mt-5 max-w-xl text-lg leading-relaxed text-muted">
      Open to Data Analyst and Data Scientist roles. The fastest way to reach me is
      email — or connect on LinkedIn and GitHub.
    </p>

    <div class="reveal mt-12 grid gap-4 sm:grid-cols-3">
      {
        channels.map((c) => (
          <a
            href={c.href}
            target={c.icon === 'mail' ? undefined : '_blank'}
            rel={c.icon === 'mail' ? undefined : 'noopener noreferrer'}
            class="group flex flex-col items-center gap-3 rounded-[14px] border border-border bg-surface/60 px-6 py-8 transition-all hover:-translate-y-1 hover:border-accent/50"
          >
            <span class="flex h-12 w-12 items-center justify-center rounded-full border border-border-strong text-muted transition-colors group-hover:border-accent group-hover:text-accent">
              {c.icon === 'mail' && (
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="2" y="4" width="20" height="16" rx="2" /><path d="m22 7-10 5L2 7" />
                </svg>
              )}
              {c.icon === 'linkedin' && (
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z" />
                </svg>
              )}
              {c.icon === 'github' && (
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 .5C5.73.5.5 5.73.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.27-.01-1.16-.02-2.1-3.2.7-3.88-1.37-3.88-1.37-.52-1.33-1.28-1.69-1.28-1.69-1.05-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.05 11.05 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.14 0 1.55-.01 2.8-.01 3.18 0 .31.21.68.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5z" />
                </svg>
              )}
            </span>
            <div>
              <p class="font-mono text-xs tracking-widest text-faint">{c.label.toUpperCase()}</p>
              <p class="mt-1 text-sm text-text">{c.value}</p>
            </div>
          </a>
        ))
      }
    </div>

    <a
      href={`mailto:${profile.email}`}
      class="reveal mt-12 inline-flex items-center gap-2 rounded-full bg-accent px-7 py-3.5 font-medium text-bg transition-transform hover:-translate-y-0.5 hover:bg-accent-soft"
    >
      Say hello
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
      </svg>
    </a>
  </div>
</section>
