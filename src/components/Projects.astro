---
import SectionHeading from './SectionHeading.astro';
import { projects } from '../data/portfolio';
---

<section id="projects" class="mx-auto max-w-5xl px-6 py-24">
  <SectionHeading
    index="04 / projects"
    title="Selected work"
    subtitle="Each pairs a real data problem with a shipped, measurable outcome."
  />

  <div class="grid gap-5 sm:grid-cols-2">
    {
      projects.map((project, i) => (
        <article
          class="reveal group relative flex flex-col overflow-hidden rounded-[14px] border border-border bg-surface/50 p-6 transition-all duration-300 hover:-translate-y-1 hover:border-accent/50"
          style={`transition-delay:${i * 70}ms`}
        >
          <div
            class="pointer-events-none absolute inset-x-0 -top-px h-px bg-gradient-to-r from-transparent via-accent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"
            aria-hidden="true"
          />

          <div class="mb-4 flex items-start justify-between gap-4">
            <h3 class="font-display text-xl font-semibold leading-snug text-text">
              {project.title}
            </h3>
            {project.github && (
              <a
                href={project.github}
                target="_blank"
                rel="noopener noreferrer"
                class="-mr-2 -mt-2 flex h-11 w-11 flex-none items-center justify-center rounded-md text-muted transition-colors hover:bg-elevated hover:text-accent"
                aria-label={`${project.title} on GitHub`}
              >
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 .5C5.73.5.5 5.73.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.27-.01-1.16-.02-2.1-3.2.7-3.88-1.37-3.88-1.37-.52-1.33-1.28-1.69-1.28-1.69-1.05-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.05 11.05 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.14 0 1.55-.01 2.8-.01 3.18 0 .31.21.68.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5z" />
                </svg>
              </a>
            )}
          </div>

          <ul class="mb-5 space-y-2">
            {project.description.map((line) => (
              <li class="flex gap-2.5 text-sm leading-relaxed text-muted">
                <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent/60" />
                {line}
              </li>
            ))}
          </ul>

          <ul class="mt-auto flex flex-wrap gap-2 pt-2">
            {project.tags.map((tag) => (
              <li class="rounded-full border border-border bg-elevated px-2.5 py-1 font-mono text-[11px] tracking-wide text-accent/90">
                {tag}
              </li>
            ))}
          </ul>
        </article>
      ))
    }
  </div>
</section>
