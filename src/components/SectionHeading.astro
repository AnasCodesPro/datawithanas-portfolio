---
interface Props {
  index: string;
  title: string;
  subtitle?: string;
}
const { index, title, subtitle } = Astro.props;
---

<div class="reveal mb-12 max-w-2xl">
  <p class="mb-3 font-mono text-sm tracking-widest text-accent">{index}</p>
  <h2 class="font-display text-3xl font-semibold tracking-tight text-text sm:text-4xl">
    {title}
  </h2>
  {subtitle && <p class="mt-4 text-base leading-relaxed text-muted">{subtitle}</p>}
  <div class="mt-5 h-px w-16 bg-gradient-to-r from-accent to-accent-2"></div>
</div>
